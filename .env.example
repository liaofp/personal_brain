# =============================================================================
# OpenClaw + Personal Brain Docker Compose 环境变量配置
# 复制本文件为 .env 并填写实际值
# =============================================================================

# -----------------------------------------------------------------------------
# 端口配置
# -----------------------------------------------------------------------------
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
# 注意：PERSONAL_BRAIN_PORT (18000) 不映射到宿主机，仅容器内部访问

# -----------------------------------------------------------------------------
# 数据持久化路径（可选，默认使用当前目录下的相对路径）
# -----------------------------------------------------------------------------
# OpenClaw 配置目录（默认: ./.openclaw-config）
# OPENCLAW_CONFIG_DIR=/path/to/your/.openclaw

# OpenClaw 工作区目录（默认: ./.openclaw-workspace）
# OPENCLAW_WORKSPACE_DIR=/path/to/your/.openclaw/workspace

# Personal Brain SQLite 数据库目录（默认: ./data）
# PERSONAL_BRAIN_DATA_DIR=/path/to/your/brain-data

# -----------------------------------------------------------------------------
# OpenClaw Gateway 配置
# -----------------------------------------------------------------------------
OPENCLAW_GATEWAY_BIND=lan

# Gateway 访问令牌（必填，绑定到 0.0.0.0 时必须设置认证）
# 可以使用以下命令生成随机令牌：openssl rand -hex 32
# 令牌保存在 .gateway-token 文件中，Web UI 登录时需要
OPENCLAW_GATEWAY_TOKEN=your-random-token-here

# 允许不安全的私有 WebSocket 连接（开发环境设为 1）
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1

# 禁用 Bonjour（容器环境建议设为 1）
OPENCLAW_DISABLE_BONJOUR=1

# -----------------------------------------------------------------------------
# LLM 模型提供商 API 密钥
# 主模型使用 Kimi Code（Moonshot AI 代码专用模型）
# -----------------------------------------------------------------------------

# Kimi Code API Key（必填）
# 获取地址: https://platform.moonshot.cn/
# 在 Moonshot 平台创建 API Key，选择 "Kimi Code" 模型权限
KIMI_CODE_API_KEY=sk-your-kimi-code-api-key-here

# OpenAI - 备用模型（可选）
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic Claude - 备用模型（可选）
# ANTHROPIC_API_KEY=sk-your-anthropic-api-key-here

# -----------------------------------------------------------------------------
# OpenTelemetry 可观测性（可选）
# -----------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# OTEL_SERVICE_NAME=openclaw-gateway

# -----------------------------------------------------------------------------
# 时区配置
# -----------------------------------------------------------------------------
TZ=Asia/Shanghai
